          label#mfp_element_14_label.mfp_not_checked(style='cursor: pointer;')
            input.mfp_element_radio.mfp_element_all#mfp_element_14(type='radio' name='お問合せ種別' value='ご依頼')
            | ご依頼
          label#mfp_element_15_label.mfp_not_checked(style='cursor: pointer;')
            input.mfp_element_radio.mfp_element_all#mfp_element_15(type='radio' name='お問合せ種別' value='その他')
