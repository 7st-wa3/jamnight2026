    dt.mfp.mfp_colored フリガナ
    dd.mfp.mfp_colored
      .mfp_rows
        .mfp_col5
          input.mfp_element_text.mfp_element_all.mfp_defaultValue#mfp_element_4(type='text' name='セイ' size='15' data-charcheck='zenkaku' style='width: 90px;')
          .mfp_err#errormsg_s
        .mfp_col5
          input.mfp_element_text.mfp_element_all.mfp_defaultValue#mfp_element_5(type='text' name='メイ' size='15' data-charcheck='kana' style='width: 90px;')
