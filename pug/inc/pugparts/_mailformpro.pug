      .mfp_rows
        .mfp_col5
          input.mfp_element_text.mfp_element_all.mfp_defaultValue#mfp_element_2(type='text' name='姓' data-kana='セイ' size='15' style='background-color: rgb(255, 0, 0); width: 90px;')
