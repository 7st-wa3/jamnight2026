//- テンプレート読み込み
extend ../inc/_layout

//-　ページ独自の設定
append pagedata
  - var pageTitle= "インデックス";
  - var pageDescription= "ページの説明";

  - var ogType = "website"
  //- - var outerClass = "blackMode"
  //- website: WebサイトのTOPページ
  //- blog: ブログのトップページ
  //- article: 記事ページなど、WebサイトのTOP以外のページ
  //- product: 製品の紹介ページ

//- ページ独自のcss
append pagecss
  link(rel="stylesheet" href="./css/cont.css?"+dateNow)

//- ページ独自のjs
append pagejs
  //- script(src="https://ajaxzip3.github.io/ajaxzip3.js" charset="UTF-8")

//- ページのコンテンツ
block main

  //- コンテンツヘッダ
