    .inner
      h1 HGT-SYSTEM v2026.6

  nav#pnkz
    .inner
      span
        a(href="index.html") TOP
      span このページ

  main#mainCont
    .inner

      section.flb

        article
          h3 プレコメニュー
          p 最終更新日：#{dateNowLoc}
